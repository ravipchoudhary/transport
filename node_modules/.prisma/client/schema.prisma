generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id             String          @id @default(cuid())
  fullName       String
  mobile         String          @unique
  email          String          @unique
  password       String
  role           String
  challans       Challan[]
  diesel         Diesel[]
  mechanic       Mechanic[]
  driver         Driver[]
  vehicles       Vehicle[]
  driverProfiles DriverProfile[]
  createdAt      DateTime        @default(now())
}

model Challan {
  id               String   @id @default(cuid())
  challanNo        String
  dealerName       String
  date             DateTime
  riceBags         Int
  wheatBags        Int
  totalBags        Int
  ratePerBag       Float
  calculatedAmount Float
  month            String
  vehicleNumber    String
  driverName       String
  scannedData      String?
  user             User     @relation(fields: [userId], references: [id])
  userId           String
  createdAt        DateTime @default(now())
}

model Diesel {
  id            String   @id @default(cuid())
  driverName    String
  vehicleNumber String
  quantity      Float
  rate          Float
  amount        Float
  date          DateTime
  givenBy       String
  remarks       String?
  month         String
  user          User     @relation(fields: [userId], references: [id])
  userId        String
  createdAt     DateTime @default(now())
}

model Mechanic {
  id              String   @id @default(cuid())
  mechanicName    String
  vehicleNumber   String
  workDescription String
  partsUsed       String?
  amountPaid      Float
  date            DateTime
  paidBy          String
  remarks         String?
  month           String
  user            User     @relation(fields: [userId], references: [id])
  userId          String
  createdAt       DateTime @default(now())
}

model Driver {
  id            String   @id @default(cuid())
  driverName    String
  mobileNumber  String
  vehicleNumber String
  amountGiven   Float
  paymentDate   DateTime
  paymentType   String
  remarks       String?
  month         String
  user          User     @relation(fields: [userId], references: [id])
  userId        String
  createdAt     DateTime @default(now())
}

model Vehicle {
  id              String    @id @default(cuid())
  vehicleNumber   String
  vehicleType     String
  ownerName       String
  rcDocument      String?
  roadTaxExpiry   DateTime?
  insuranceExpiry DateTime?
  pucExpiry       DateTime?
  fitnessExpiry   DateTime?
  permitExpiry    DateTime?
  remarks         String?
  user            User      @relation(fields: [userId], references: [id])
  userId          String
  createdAt       DateTime  @default(now())
}

model DriverProfile {
  id                    String    @id @default(cuid())
  driverName            String
  mobileNumber          String
  address               String?
  aadhaarNumber         String?
  aadhaarPhoto          String?
  licenseNumber         String
  licensePhoto          String?
  driverPhoto           String?
  assignedVehicleNumber String?
  joiningDate           DateTime?
  remarks               String?
  user                  User      @relation(fields: [userId], references: [id])
  userId                String
  createdAt             DateTime  @default(now())
}
